{
	"manifest_version": 3,
	"name": "KimiZK Translator",
	"version": "1.0",
	"description": "Dịch từ tự động khi bôi đen văn bản",
	"permissions": ["scripting", "activeTab"],
	"host_permissions": [
		"<all_urls>",
		"https://api.groq.com/openai/v1/chat/completions",
		"https://api.groq.com/openai/v1/audio/speech"
	],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["main.js"],
			"css": ["styles.css"]
		}
	],
	"web_accessible_resources": [
    {
      "resources": ["icons/icon16.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
