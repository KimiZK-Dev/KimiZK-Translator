{
	"manifest_version": 3,
	"name": "KimiZK Translator",
	"version": "1.0",
	"description": "Dịch từ tự động khi bôi đen văn bản",
	"permissions": ["scripting", "activeTab"],
	"host_permissions": ["<all_urls>"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["main.js"],
			"css": ["styles.css"]
		}
	]
}
